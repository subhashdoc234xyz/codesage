# Gemini API Key (Required for AI Review)
# Get a key at https://aistudio.google.com/
GEMINI_API_KEY=

# GitHub Personal Access Token (Optional for public repos, recommended to bypass rate limiting)
# Get a token at https://github.com/settings/tokens
GITHUB_TOKEN=

# Gmail SMTP (Free email notifications — 500 emails/day)
# Step 1: Enable 2-Step Verification at https://myaccount.google.com/security
# Step 2: Generate App Password at https://myaccount.google.com → Security → App passwords
GMAIL_USER=
GMAIL_APP_PASSWORD=
